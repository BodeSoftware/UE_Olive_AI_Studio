{
    "template_id": "projectile",
    "template_type": "factory",
    "display_name": "Projectile",

    "catalog_description": "Actor with collision, mesh, and ProjectileMovementComponent. Configurable speed, gravity, and lifespan. Use projectile_patterns reference template for hit/damage/bounce logic.",
    "catalog_examples": "Bullet, Rocket, Arrow, Grenade, Fireball, Cannonball",

    "parameters": {
        "projectile_name": {
            "type": "string",
            "default": "Projectile",
            "description": "Name prefix for the mesh component and damage variable"
        },
        "speed": {
            "type": "float",
            "default": "3000.0",
            "description": "Initial speed in cm/s"
        },
        "max_speed": {
            "type": "float",
            "default": "3000.0",
            "description": "Maximum speed in cm/s"
        },
        "gravity_scale": {
            "type": "float",
            "default": "0.0",
            "description": "Gravity multiplier (0 = no gravity, 1 = normal)"
        },
        "should_bounce": {
            "type": "bool",
            "default": "false",
            "description": "Allow bouncing off surfaces"
        },
        "enable_homing": {
            "type": "bool",
            "default": "false",
            "description": "Enable homing toward a target"
        },
        "homing_strength": {
            "type": "float",
            "default": "500.0",
            "description": "Homing acceleration magnitude when homing is enabled"
        },
        "collision_radius": {
            "type": "float",
            "default": "10.0",
            "description": "Radius of the collision sphere in cm"
        },
        "damage": {
            "type": "float",
            "default": "20.0",
            "description": "Base damage value stored as a variable"
        }
    },

    "presets": {
        "Bullet": {
            "projectile_name": "Bullet",
            "speed": "5000",
            "max_speed": "5000",
            "gravity_scale": "0",
            "damage": "25"
        },
        "Rocket": {
            "projectile_name": "Rocket",
            "speed": "2000",
            "max_speed": "2000",
            "gravity_scale": "0.05",
            "damage": "100"
        },
        "Grenade": {
            "projectile_name": "Grenade",
            "speed": "1500",
            "max_speed": "1500",
            "gravity_scale": "1.0",
            "damage": "75",
            "should_bounce": "true"
        },
        "Arrow": {
            "projectile_name": "Arrow",
            "speed": "4000",
            "max_speed": "4000",
            "gravity_scale": "0.3",
            "damage": "40"
        },
        "HomingMissile": {
            "projectile_name": "Missile",
            "speed": "1800",
            "max_speed": "3000",
            "gravity_scale": "0",
            "damage": "80",
            "enable_homing": "true",
            "homing_strength": "800"
        },
        "Fireball": {
            "projectile_name": "Fireball",
            "speed": "2500",
            "max_speed": "2500",
            "gravity_scale": "0.1",
            "damage": "50",
            "collision_radius": "20"
        }
    },

    "blueprint": {
        "type": "Actor",
        "parent_class": "Actor",

        "components": [
            {
                "class": "SphereComponent",
                "name": "CollisionSphere",
                "is_root": true,
                "properties": {
                    "SphereRadius": "${collision_radius}",
                    "CollisionProfileName": "BlockAllDynamic"
                }
            },
            {
                "class": "StaticMeshComponent",
                "name": "${projectile_name}Mesh",
                "parent": "CollisionSphere",
                "properties": {
                    "CollisionProfileName": "NoCollision"
                }
            },
            {
                "class": "ProjectileMovementComponent",
                "name": "ProjectileMovement",
                "properties": {
                    "InitialSpeed": "${speed}",
                    "MaxSpeed": "${max_speed}",
                    "ProjectileGravityScale": "${gravity_scale}",
                    "bShouldBounce": "${should_bounce}",
                    "bIsHomingProjectile": "${enable_homing}",
                    "HomingAccelerationMagnitude": "${homing_strength}"
                }
            }
        ],

        "variables": [
            {
                "name": "${projectile_name}Damage",
                "type": "Float",
                "default": "${damage}",
                "category": "${projectile_name}"
            }
        ],

        "functions": [
            {
                "name": "InitProjectile",
                "description": "BeginPlay event graph chain: sets lifespan for auto-destroy, then gets the owner actor and tells the collision sphere to ignore it to prevent self-hit on spawn. Target graph: EventGraph.",
                "inputs": [],
                "outputs": [],
                "plan": {
                    "steps": [
                        { "step_id": "s_begin", "op": "event", "target": "ReceiveBeginPlay" },
                        { "step_id": "s_lifespan", "op": "call", "target": "SetLifeSpan",
                          "inputs": { "InLifespan": "3.0" },
                          "exec_after": "s_begin" },
                        { "step_id": "s_get_owner", "op": "call", "target": "GetOwner" },
                        { "step_id": "s_valid", "op": "is_valid",
                          "inputs": { "Object": "@s_get_owner.ReturnValue" },
                          "exec_after": "s_lifespan",
                          "exec_outputs": { "IsValid": "s_get_sphere" } },
                        { "step_id": "s_get_sphere", "op": "get_var", "target": "CollisionSphere" },
                        { "step_id": "s_ignore", "op": "call", "target": "IgnoreActorWhenMoving",
                          "inputs": { "Target": "@s_get_sphere.CollisionSphere", "Actor": "@s_get_owner.ReturnValue", "bShouldIgnore": "true" },
                          "exec_after": "s_valid" }
                    ]
                }
            },
            {
                "name": "HitResponse",
                "description": "OnComponentHit event graph chain on CollisionSphere: applies damage to the hit actor using the projectile's damage variable and instigator controller, then destroys the projectile. Target graph: EventGraph.",
                "inputs": [],
                "outputs": [],
                "plan": {
                    "steps": [
                        { "step_id": "s_hit", "op": "event", "target": "OnComponentHit",
                          "properties": { "component_name": "CollisionSphere" } },
                        { "step_id": "s_get_dmg", "op": "get_var", "target": "${projectile_name}Damage" },
                        { "step_id": "s_get_instigator", "op": "call", "target": "GetInstigatorController" },
                        { "step_id": "s_apply_dmg", "op": "call", "target": "ApplyDamage",
                          "inputs": {
                              "DamagedActor": "@s_hit.OtherActor",
                              "BaseDamage": "@s_get_dmg.auto",
                              "EventInstigator": "@s_get_instigator.ReturnValue",
                              "DamageCauser": "@self.auto"
                          },
                          "exec_after": "s_hit" },
                        { "step_id": "s_destroy", "op": "call", "target": "DestroyActor",
                          "exec_after": "s_apply_dmg" }
                    ]
                }
            }
        ]
    }
}
