{
    "template_id": "gun",
    "template_type": "factory",
    "display_name": "Gun",

    "catalog_description": "Actor with mesh, muzzle point, fire/reload functions, ammo tracking, and event dispatchers. Pair with the projectile template for a complete weapon system.",
    "catalog_examples": "Pistol, Rifle, Shotgun, SMG, Sniper, Launcher",

    "parameters": {
        "weapon_name": {
            "type": "string",
            "default": "Gun",
            "description": "Name prefix for variables and events"
        },
        "max_ammo": {
            "type": "int",
            "default": "30",
            "description": "Maximum ammo capacity"
        },
        "start_loaded": {
            "type": "bool",
            "default": "true",
            "description": "Start at max ammo (true) or zero (false)"
        },
        "fire_rate": {
            "type": "float",
            "default": "5.0",
            "description": "Shots per second"
        },
        "damage": {
            "type": "float",
            "default": "20.0",
            "description": "Base damage per shot"
        },
        "muzzle_velocity": {
            "type": "float",
            "default": "5000.0",
            "description": "Projectile launch speed in cm/s"
        }
    },

    "presets": {
        "Pistol": {
            "weapon_name": "Pistol",
            "max_ammo": "12",
            "fire_rate": "3",
            "damage": "25",
            "muzzle_velocity": "5000"
        },
        "Rifle": {
            "weapon_name": "Rifle",
            "max_ammo": "30",
            "fire_rate": "10",
            "damage": "15",
            "muzzle_velocity": "8000"
        },
        "Shotgun": {
            "weapon_name": "Shotgun",
            "max_ammo": "8",
            "fire_rate": "1",
            "damage": "80",
            "muzzle_velocity": "4000"
        },
        "SMG": {
            "weapon_name": "SMG",
            "max_ammo": "25",
            "fire_rate": "15",
            "damage": "10",
            "muzzle_velocity": "6000"
        },
        "Sniper": {
            "weapon_name": "Sniper",
            "max_ammo": "5",
            "fire_rate": "0.5",
            "damage": "150",
            "muzzle_velocity": "15000"
        }
    },

    "blueprint": {
        "type": "Actor",
        "parent_class": "Actor",

        "components": [
            {
                "class": "SceneComponent",
                "name": "Root",
                "is_root": true
            },
            {
                "class": "StaticMeshComponent",
                "name": "${weapon_name}Mesh",
                "parent": "Root",
                "properties": {
                    "CollisionProfileName": "NoCollision"
                }
            },
            {
                "class": "SceneComponent",
                "name": "MuzzlePoint",
                "parent": "${weapon_name}Mesh"
            }
        ],

        "variables": [
            {
                "name": "CurrentAmmo",
                "type": "Integer",
                "default": "${start_loaded} ? ${max_ammo} : 0",
                "category": "${weapon_name}"
            },
            {
                "name": "MaxAmmo",
                "type": "Integer",
                "default": "${max_ammo}",
                "category": "${weapon_name}"
            },
            {
                "name": "${weapon_name}Damage",
                "type": "Float",
                "default": "${damage}",
                "category": "${weapon_name}"
            },
            {
                "name": "MuzzleVelocity",
                "type": "Float",
                "default": "${muzzle_velocity}",
                "category": "${weapon_name}"
            },
            {
                "name": "FireRate",
                "type": "Float",
                "default": "${fire_rate}",
                "category": "${weapon_name}"
            },
            {
                "name": "bCanFire",
                "type": "Boolean",
                "default": "true",
                "category": "${weapon_name}"
            }
        ],

        "event_dispatchers": [
            {
                "name": "OnFired",
                "params": [
                    { "name": "RemainingAmmo", "type": "Integer" }
                ]
            },
            {
                "name": "OnAmmoEmpty",
                "params": []
            },
            {
                "name": "OnReloaded",
                "params": [
                    { "name": "NewAmmo", "type": "Integer" }
                ]
            }
        ],

        "functions": [
            {
                "name": "Fire",
                "description": "Attempt to fire. Decrements ammo if available, fires OnFired. When ammo reaches zero, fires OnAmmoEmpty.",
                "inputs": [],
                "outputs": [
                    { "name": "bSuccess", "type": "Boolean" }
                ]
            },
            {
                "name": "ResetCanFire",
                "description": "Called by timer to re-enable firing after cooldown.",
                "inputs": [],
                "outputs": []
            },
            {
                "name": "Reload",
                "description": "Restore ammo to max and fire OnReloaded.",
                "inputs": [],
                "outputs": [
                    { "name": "NewAmmo", "type": "Integer" }
                ]
            }
        ]
    }
}
