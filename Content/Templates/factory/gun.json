{
    "template_id": "gun",
    "template_type": "factory",
    "display_name": "Gun",

    "catalog_description": "Actor with mesh, muzzle point, fire/reload functions with full graph logic, ammo tracking, cooldown timer, and event dispatchers. Pair with the projectile template for a complete weapon system.",
    "catalog_examples": "Pistol, Rifle, Shotgun, SMG, Sniper, Launcher",
    "usage_notes": "Equipping: Cast overlapping actor to Character, get the character's Mesh (SkeletalMeshComponent), attach the weapon via K2_AttachToComponent with SocketName (hand_r or weapon_r) and all rules set to SnapToTarget, then disable collision on the weapon mesh (NOT the PickupSphere). Self-collision prevention: After SpawnActor for the projectile, call SetOwner(self) on it. The projectile's BeginPlay should then call IgnoreActorWhenMoving(GetOwner(), true) on its collision component.",

    "parameters": {
        "weapon_name": {
            "type": "string",
            "default": "Gun",
            "description": "Name prefix for variables and events"
        },
        "max_ammo": {
            "type": "int",
            "default": "30",
            "description": "Maximum ammo capacity"
        },
        "start_loaded": {
            "type": "bool",
            "default": "true",
            "description": "Start at max ammo (true) or zero (false)"
        },
        "fire_rate": {
            "type": "float",
            "default": "5.0",
            "description": "Shots per second"
        },
        "damage": {
            "type": "float",
            "default": "20.0",
            "description": "Base damage per shot"
        },
        "muzzle_velocity": {
            "type": "float",
            "default": "5000.0",
            "description": "Projectile launch speed in cm/s"
        }
    },

    "presets": {
        "Pistol": {
            "weapon_name": "Pistol",
            "max_ammo": "12",
            "fire_rate": "3",
            "damage": "25",
            "muzzle_velocity": "5000"
        },
        "Rifle": {
            "weapon_name": "Rifle",
            "max_ammo": "30",
            "fire_rate": "10",
            "damage": "15",
            "muzzle_velocity": "8000"
        },
        "Shotgun": {
            "weapon_name": "Shotgun",
            "max_ammo": "8",
            "fire_rate": "1",
            "damage": "80",
            "muzzle_velocity": "4000"
        },
        "SMG": {
            "weapon_name": "SMG",
            "max_ammo": "25",
            "fire_rate": "15",
            "damage": "10",
            "muzzle_velocity": "6000"
        },
        "Sniper": {
            "weapon_name": "Sniper",
            "max_ammo": "5",
            "fire_rate": "0.5",
            "damage": "150",
            "muzzle_velocity": "15000"
        }
    },

    "blueprint": {
        "type": "Actor",
        "parent_class": "Actor",

        "components": [
            {
                "class": "SceneComponent",
                "name": "Root",
                "is_root": true
            },
            {
                "class": "StaticMeshComponent",
                "name": "${weapon_name}Mesh",
                "parent": "Root",
                "properties": {
                    "CollisionProfileName": "NoCollision"
                }
            },
            {
                "class": "SceneComponent",
                "name": "MuzzlePoint",
                "parent": "${weapon_name}Mesh"
            }
        ],

        "variables": [
            {
                "name": "CurrentAmmo",
                "type": "Integer",
                "default": "${start_loaded} ? ${max_ammo} : 0",
                "category": "${weapon_name}"
            },
            {
                "name": "MaxAmmo",
                "type": "Integer",
                "default": "${max_ammo}",
                "category": "${weapon_name}"
            },
            {
                "name": "${weapon_name}Damage",
                "type": "Float",
                "default": "${damage}",
                "category": "${weapon_name}"
            },
            {
                "name": "MuzzleVelocity",
                "type": "Float",
                "default": "${muzzle_velocity}",
                "category": "${weapon_name}"
            },
            {
                "name": "FireRate",
                "type": "Float",
                "default": "${fire_rate}",
                "category": "${weapon_name}"
            },
            {
                "name": "bCanFire",
                "type": "Boolean",
                "default": "true",
                "category": "${weapon_name}"
            },
            {
                "name": "bFireResult",
                "type": "Boolean",
                "default": "false",
                "category": "${weapon_name}"
            }
        ],

        "event_dispatchers": [
            {
                "name": "OnFired",
                "params": [
                    { "name": "RemainingAmmo", "type": "Integer" }
                ]
            },
            {
                "name": "OnAmmoEmpty",
                "params": []
            },
            {
                "name": "OnReloaded",
                "params": [
                    { "name": "NewAmmo", "type": "Integer" }
                ]
            }
        ],

        "functions": [
            {
                "name": "Fire",
                "description": "Attempt to fire. Checks bCanFire and ammo, decrements ammo, starts cooldown timer, fires OnFired. When ammo reaches zero, fires OnAmmoEmpty. Uses set_var pattern for multiple exit paths.",
                "category": "${weapon_name}",
                "access": "public",
                "inputs": [],
                "outputs": [
                    { "name": "bSuccess", "type": "Boolean" }
                ],
                "plan": {
                    "steps": [
                        { "step_id": "s_get_can_fire", "op": "get_var", "target": "bCanFire" },
                        { "step_id": "s_get_ammo", "op": "get_var", "target": "CurrentAmmo" },
                        { "step_id": "s_check_ammo_gt0", "op": "call", "target": "Greater_IntInt",
                          "inputs": { "A": "@s_get_ammo.CurrentAmmo", "B": "0" } },
                        { "step_id": "s_calc_new_ammo", "op": "call", "target": "Subtract_IntInt",
                          "inputs": { "A": "@s_get_ammo.CurrentAmmo", "B": "1" } },
                        { "step_id": "s_get_fire_rate", "op": "get_var", "target": "FireRate" },
                        { "step_id": "s_calc_cooldown", "op": "call", "target": "Divide_DoubleDouble",
                          "inputs": { "A": "1.0", "B": "@s_get_fire_rate.FireRate" } },
                        { "step_id": "s_check_empty", "op": "call", "target": "EqualEqual_IntInt",
                          "inputs": { "A": "@s_calc_new_ammo.ReturnValue", "B": "0" } },
                        { "step_id": "s_get_result", "op": "get_var", "target": "bFireResult" },
                        { "step_id": "s_init_fail", "op": "set_var", "target": "bFireResult",
                          "inputs": { "bFireResult": "false" } },
                        { "step_id": "s_check_can_fire", "op": "branch",
                          "inputs": { "Condition": "@s_get_can_fire.bCanFire" },
                          "exec_after": "s_init_fail",
                          "exec_outputs": { "True": "s_branch_ammo", "False": "s_return" } },
                        { "step_id": "s_branch_ammo", "op": "branch",
                          "inputs": { "Condition": "@s_check_ammo_gt0.ReturnValue" },
                          "exec_outputs": { "True": "s_set_ammo", "False": "s_return" } },
                        { "step_id": "s_set_ammo", "op": "set_var", "target": "CurrentAmmo",
                          "inputs": { "CurrentAmmo": "@s_calc_new_ammo.ReturnValue" } },
                        { "step_id": "s_disable_fire", "op": "set_var", "target": "bCanFire",
                          "inputs": { "bCanFire": "false" },
                          "exec_after": "s_set_ammo" },
                        { "step_id": "s_set_timer", "op": "call", "target": "SetTimer",
                          "inputs": { "FunctionName": "ResetCanFire", "Time": "@s_calc_cooldown.ReturnValue", "bLooping": "false" },
                          "exec_after": "s_disable_fire" },
                        { "step_id": "s_call_on_fired", "op": "call_delegate", "target": "OnFired",
                          "inputs": { "RemainingAmmo": "@s_calc_new_ammo.ReturnValue" },
                          "exec_after": "s_set_timer" },
                        { "step_id": "s_branch_empty", "op": "branch",
                          "inputs": { "Condition": "@s_check_empty.ReturnValue" },
                          "exec_after": "s_call_on_fired",
                          "exec_outputs": { "True": "s_call_empty", "False": "s_set_success" } },
                        { "step_id": "s_call_empty", "op": "call_delegate", "target": "OnAmmoEmpty" },
                        { "step_id": "s_set_success", "op": "set_var", "target": "bFireResult",
                          "inputs": { "bFireResult": "true" },
                          "exec_after": "s_call_empty" },
                        { "step_id": "s_return", "op": "return",
                          "inputs": { "bSuccess": "@s_get_result.bFireResult" },
                          "exec_after": "s_set_success" }
                    ]
                }
            },
            {
                "name": "ResetCanFire",
                "description": "Called by cooldown timer to re-enable firing.",
                "category": "${weapon_name}",
                "access": "private",
                "inputs": [],
                "outputs": [],
                "plan": {
                    "steps": [
                        { "step_id": "s_enable", "op": "set_var", "target": "bCanFire",
                          "inputs": { "bCanFire": "true" } }
                    ]
                }
            },
            {
                "name": "Reload",
                "description": "Restore ammo to max and fire OnReloaded.",
                "category": "${weapon_name}",
                "access": "public",
                "inputs": [],
                "outputs": [
                    { "name": "NewAmmo", "type": "Integer" }
                ],
                "plan": {
                    "steps": [
                        { "step_id": "s_get_max", "op": "get_var", "target": "MaxAmmo" },
                        { "step_id": "s_set_ammo", "op": "set_var", "target": "CurrentAmmo",
                          "inputs": { "CurrentAmmo": "@s_get_max.MaxAmmo" } },
                        { "step_id": "s_enable_fire", "op": "set_var", "target": "bCanFire",
                          "inputs": { "bCanFire": "true" },
                          "exec_after": "s_set_ammo" },
                        { "step_id": "s_call_reloaded", "op": "call_delegate", "target": "OnReloaded",
                          "inputs": { "NewAmmo": "@s_get_max.MaxAmmo" },
                          "exec_after": "s_enable_fire" },
                        { "step_id": "s_return", "op": "return",
                          "inputs": { "NewAmmo": "@s_get_max.MaxAmmo" },
                          "exec_after": "s_call_reloaded" }
                    ]
                }
            }
        ]
    }
}
