{
	"FileVersion": 3,
	"Version": 1,
	"VersionName": "0.1.0-alpha",
	"FriendlyName": "Olive AI Studio",
	"Description": "AI-powered development assistant for Unreal Engine. Features built-in chat UI, Claude Code integration via MCP, intelligent asset search, and future Blueprint/BT/PCG editing capabilities.",
	"Category": "Editor",
	"CreatedBy": "Bode Software",
	"CreatedByURL": "https://bodesoftware.com/",
	"DocsURL": "https://github.com/yourusername/olive-ai-studio",
	"MarketplaceURL": "",
	"SupportURL": "https://github.com/yourusername/olive-ai-studio/issues",
	"CanContainContent": true,
	"IsBetaVersion": true,
	"IsExperimentalVersion": false,
	"Installed": false,
	"Modules": [
		{
			"Name": "OliveAIRuntime",
			"Type": "Runtime",
			"LoadingPhase": "Default"
		},
		{
			"Name": "OliveAIEditor",
			"Type": "Editor",
			"LoadingPhase": "PostEngineInit"
		}
	],
	"Plugins": [
		{
			"Name": "EditorScriptingUtilities",
			"Enabled": true
		},
		{
			"Name": "PCG",
			"Enabled": true
		},
		{
			"Name": "EnhancedInput",
			"Enabled": true
		}
	]
}
